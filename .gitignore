# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Jupyter notebooks checkpoints
.ipynb_checkpoints/

# Large Yelp raw data files — never commit these
data/raw/*.json
data/raw/*.csv
data/raw/*.tar
data/raw/*.tgz

# Processed data and embeddings — too large for git
data/interim/*.csv
data/processed/*.csv
data/processed/*.npy

# Keep the directory structure in git
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# Sentence-transformers model cache
.cache/
models/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# Environment variables
.env
